{
  "name": "metrics-collector",
  "version": "0.1.0",
  "private": true,
  "description": "Lambda that consumes CodeCommit EventBridge events and emits review metrics.",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "../.config/node_modules/.bin/eslint --config ../.config/eslint.config.mjs src",
    "lint:fix": "../.config/node_modules/.bin/eslint --config ../.config/eslint.config.mjs --fix src",
    "format": "../.config/node_modules/.bin/prettier --config ../.config/.prettierrc.json --ignore-path ../.config/.prettierignore --write \"src/**/*.ts\"",
    "format:check": "../.config/node_modules/.bin/prettier --config ../.config/.prettierrc.json --ignore-path ../.config/.prettierignore --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^22.7.5",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3"
  }
}
