{
  "name": "aws-code-review-optimization-cdk",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "cdk-app": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "lint": "../.config/node_modules/.bin/eslint --config ../.config/eslint.config.mjs bin lib",
    "lint:fix": "../.config/node_modules/.bin/eslint --config ../.config/eslint.config.mjs --fix bin lib",
    "format": "../.config/node_modules/.bin/prettier --config ../.config/.prettierrc.json --ignore-path ../.config/.prettierignore --write \"{bin,lib}/**/*.ts\"",
    "format:check": "../.config/node_modules/.bin/prettier --config ../.config/.prettierrc.json --ignore-path ../.config/.prettierignore --check \"{bin,lib}/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2"
  }
}
